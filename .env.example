# Hugging Face model cache on host (mounted into vLLM container)
HF_CACHE=~/.cache/huggingface

# Copy to .env: cp .env.example .env

SURYA_AUTH_USER=admin
SURYA_AUTH_PASSWORD=changeme

# GPU for vLLM (0 = first 3090, 1 = second 3090)
VLLM_GPU=1

# Host ports
VLLM_HOST_PORT=8001
UI_HOST_PORT=7860

# Qwen classification via Ollama on the host
OLLAMA_BASE_URL=http://host.docker.internal:11434
QWEN_MODEL=qwen2.5:3b

# Max OCR characters sent to the LLM (classify/extract/summarize)
MAX_OCR_CHARS_FOR_LLM=12000
# Sampling temperature for document summaries
SUMMARY_TEMPERATURE=0.3

# REST API (Document Intelligence)
DOC_INTEL_API_TOKEN=change-me-to-a-secret-token
DOC_INTEL_PUBLIC_BASE_URL=http://localhost:7860
DOC_INTEL_VERSION=1.0.0
DOC_INTEL_CALLBACK_FULL_RESULT=false
